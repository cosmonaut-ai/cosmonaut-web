# =============================================================================
# Cosmonaut Web - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values.
# All PUBLIC_ vars are embedded in the client bundle at build time.

PUBLIC_API_BASE_URL=http://localhost:8000
PUBLIC_STREAMING_BASE_URL=http://localhost:8000
PUBLIC_COGNITO_USER_POOL_ID=us-east-2_XXXXXXXXX
PUBLIC_COGNITO_CLIENT_ID=your_cognito_client_id
PUBLIC_COGNITO_DOMAIN=cosmonaut-dev.auth.us-east-2.amazoncognito.com
PUBLIC_COGNITO_REDIRECT_URI=http://localhost:5173/callback
PUBLIC_AWS_REGION=us-east-2
