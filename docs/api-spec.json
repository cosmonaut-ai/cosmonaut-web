		"/worlds/{world_id}/nodes/{node_id}/choose": {
			"post": {
				"tags": ["story-nodes"],
				"summary": "Choose an option and generate the next story node (streaming)",
				"description": "Select a choice from the current node and stream the generated text of the next story node.\n\nThis endpoint accepts either:\n- `choice_index`: Index of an existing choice (0-based)\n- `custom_choice`: Free text custom choice (max 200 characters)\n\nExactly one of these must be provided.\n\nThe endpoint:\n1. Validates the input (choice index bounds or custom choice length)\n2. For custom choices, adds the choice to the node's choice list\n3. Generates a new story node text stream based on the selected/custom choice\n4. Updates the parent node's choice to link to the new node (after stream finishes)\n5. Returns a stream of the generated text using Server-Sent Events (SSE) format",
				"operationId": "choose_worlds__world_id__nodes__node_id__choose_post",
				"security": [
					{
						"HTTPBearer": []
					}
				],
				"parameters": [
					{
						"name": "world_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"description": "Identifier for the world",
							"title": "World Id"
						},
						"description": "Identifier for the world"
					},
					{
						"name": "node_id",
						"in": "path",
						"required": true,
						"schema": {
							"type": "string",
							"description": "Identifier for the current node",
							"title": "Node Id"
						},
						"description": "Identifier for the current node"
					}
				],
				"requestBody": {
					"required": true,
					"content": {
						"application/json": {
							"schema": {
								"$ref": "#/components/schemas/ChooseRequestDTO"
							}
						}
					}
				},
				"responses": {
					"201": {
						"description": "Successful Response",
						"content": {
							"application/json": {
								"schema": {}
							}
						}
